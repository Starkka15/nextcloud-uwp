<Application
    x:Class="NextcloudUWP.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NextcloudUWP"
    RequestedTheme="Light">

    <Application.Resources>
        <SolidColorBrush x:Key="NextcloudBlue" Color="#0082c9" />
        <SolidColorBrush x:Key="NextcloudDarkBlue" Color="#006AA3" />
        <SolidColorBrush x:Key="NextcloudLightGray" Color="#F5F5F5" />
        <SolidColorBrush x:Key="NextcloudMediumGray" Color="#E0E0E0" />
        <SolidColorBrush x:Key="NextcloudDarkGray" Color="#333333" />
        <SolidColorBrush x:Key="NextcloudTextPrimary" Color="#212121" />
        <SolidColorBrush x:Key="NextcloudTextSecondary" Color="#757575" />
    </Application.Resources>

</Application>
