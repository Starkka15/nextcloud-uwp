<Page x:Class="NextcloudUWP.Views.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:NextcloudUWP.Views"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#0082c9" Padding="12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button x:Name="BackButton" Grid.Column="0"
                    Click="BackButton_Click" Visibility="Collapsed"
                    Foreground="White" Background="Transparent">
                <SymbolIcon Symbol="Back" />
            </Button>
            <TextBlock x:Name="TitleText" Grid.Column="1"
                       Text="Nextcloud" Foreground="White"
                       VerticalAlignment="Center" FontSize="18"
                       Margin="12,0,0,0" />
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <AppBarButton x:Name="SearchButton" Icon="Find"
                              Foreground="White" Click="Search_Click" />
                <AppBarButton x:Name="SortButton" Foreground="White" Click="Sort_Click">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE8CB;" FontFamily="Segoe MDL2 Assets" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton x:Name="RefreshButton" Icon="Refresh"
                              Foreground="White" Click="RefreshButton_Click" />
                <AppBarButton x:Name="UploadButton" Icon="Upload"
                              Foreground="White" Click="UploadButton_Click" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <TextBlock x:Name="EmptyText"
                       Text="No files found"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="#757575"
                       Visibility="Collapsed" />
            <ListView x:Name="FileListView"
                      IsItemClickEnabled="True"
                      ItemClick="FileListView_ItemClick">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="4,8" HorizontalAlignment="Stretch"
                              RightTapped="File_RightTapped"
                              Holding="File_Holding">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding IconGlyph}"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="28" Foreground="#0082c9"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}"
                                           FontSize="14" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding DetailText}"
                                           FontSize="12" Foreground="#757575" />
                            </StackPanel>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding FavoriteGlyph}"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14" Foreground="#f0a800"
                                       VerticalAlignment="Center"
                                       Margin="4,0" />
                            <TextBlock Grid.Column="3"
                                       Text="{Binding SizeText}"
                                       FontSize="12" Foreground="#757575"
                                       VerticalAlignment="Center"
                                       Margin="8,0" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <ProgressRing x:Name="LoadingRing"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          IsActive="False" />
        </Grid>

        <CommandBar Grid.Row="2" x:Name="BottomBar">
            <CommandBar.PrimaryCommands>
                <AppBarButton Icon="Add" Label="New Folder" Click="NewFolder_Click" />
                <AppBarButton Icon="Camera" Label="Upload" Click="UploadButton_Click" />
                <AppBarButton Icon="Sync" Label="Sync" Click="RefreshButton_Click" />
            </CommandBar.PrimaryCommands>
            <CommandBar.SecondaryCommands>
                <AppBarButton Label="Settings" Click="Settings_Click" />
                <AppBarButton Label="Accounts" Click="Accounts_Click" />
                <AppBarButton Label="Search" Click="Search_Click" />
                <AppBarButton Label="Trash" Click="Trashbin_Click" />
                <AppBarButton Label="Notifications" Click="Notifications_Click" />
                <AppBarButton Label="Activity" Click="Activities_Click" />
            </CommandBar.SecondaryCommands>
        </CommandBar>
    </Grid>
</Page>
