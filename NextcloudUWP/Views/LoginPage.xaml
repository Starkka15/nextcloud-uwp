<Page x:Class="NextcloudUWP.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:NextcloudUWP.Views"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="1" MaxWidth="400" Padding="24">
            <TextBlock x:Name="TitleText" Text="Nextcloud" FontSize="36" FontWeight="Bold"
                       Foreground="#0082c9" HorizontalAlignment="Center" Margin="0,0,0,8" />
            <TextBlock Text="Sign in to your server" FontSize="16"
                       Foreground="#757575" HorizontalAlignment="Center" Margin="0,0,0,32" />

            <TextBox x:Name="ServerUrlBox" Header="Server address"
                     PlaceholderText="https://cloud.example.com"
                     InputScope="Url" Margin="0,0,0,16" />

            <TextBox x:Name="UsernameBox" Header="Username"
                     PlaceholderText="Username" Margin="0,0,0,16" />

            <PasswordBox x:Name="PasswordBox" Header="Password"
                         PlaceholderText="Password" Margin="0,0,0,24" />

            <Button x:Name="LoginButton" Content="Sign in"
                    HorizontalAlignment="Stretch" Click="LoginButton_Click"
                    Background="#0082c9" Foreground="White" />

            <ProgressRing x:Name="LoginProgress" HorizontalAlignment="Center"
                          IsActive="False" Margin="0,16,0,0" />

            <TextBlock x:Name="ErrorText" Foreground="Red"
                       TextWrapping="Wrap" HorizontalAlignment="Center"
                       Visibility="Collapsed" Margin="0,16,0,0" />
        </StackPanel>
    </Grid>
</Page>
