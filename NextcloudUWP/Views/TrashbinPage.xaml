<Page x:Class="NextcloudUWP.Views.TrashbinPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Background="#0082c9" Padding="12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Click="BackButton_Click"
                    Foreground="White" Background="Transparent">
                <SymbolIcon Symbol="Back" />
            </Button>
            <TextBlock Grid.Column="1" Text="Trash"
                       Foreground="White" VerticalAlignment="Center"
                       FontSize="18" Margin="8,0,0,0" />
        </Grid>

        <!-- List -->
        <Grid Grid.Row="1">
            <TextBlock x:Name="EmptyText"
                       Text="Trash is empty"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="#757575"
                       Visibility="Collapsed" />
            <ListView x:Name="TrashListView"
                      SelectionMode="Single">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="4,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0"
                                      Glyph="&#xE74D;" FontSize="28"
                                      Foreground="#757575" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}"
                                           FontSize="14" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding DetailText}"
                                           FontSize="12" Foreground="#757575"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding SizeText}"
                                       FontSize="12" Foreground="#757575"
                                       VerticalAlignment="Center"
                                       Margin="8,0" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <ProgressRing x:Name="LoadingRing"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          IsActive="False" />
        </Grid>

        <!-- Commands -->
        <CommandBar Grid.Row="2">
            <CommandBar.PrimaryCommands>
                <AppBarButton Icon="Undo" Label="Restore" Click="Restore_Click" />
                <AppBarButton Icon="Delete" Label="Delete" Click="DeletePermanently_Click" />
            </CommandBar.PrimaryCommands>
            <CommandBar.SecondaryCommands>
                <AppBarButton Label="Empty Trash" Click="EmptyTrash_Click" />
            </CommandBar.SecondaryCommands>
        </CommandBar>
    </Grid>
</Page>
