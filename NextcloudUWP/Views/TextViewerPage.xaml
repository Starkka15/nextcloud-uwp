<Page x:Class="NextcloudUWP.Views.TextViewerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Background="#0082c9" Padding="12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Click="BackButton_Click"
                    Foreground="White" Background="Transparent">
                <SymbolIcon Symbol="Back" />
            </Button>
            <TextBlock x:Name="TitleText" Grid.Column="1"
                       Foreground="White" VerticalAlignment="Center"
                       FontSize="16" Margin="8,0,0,0"
                       TextTrimming="CharacterEllipsis" />
        </Grid>

        <!-- Content area -->
        <Grid Grid.Row="1">
            <ScrollViewer Padding="16">
                <TextBlock x:Name="ContentText"
                           FontFamily="Consolas, Courier New"
                           FontSize="13"
                           TextWrapping="Wrap"
                           IsTextSelectionEnabled="True" />
            </ScrollViewer>

            <ProgressRing x:Name="LoadingRing"
                          IsActive="True" Width="60" Height="60"
                          HorizontalAlignment="Center" VerticalAlignment="Center" />

            <TextBlock x:Name="ErrorText"
                       Foreground="#757575" FontSize="14"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="Collapsed" />
        </Grid>
    </Grid>
</Page>
